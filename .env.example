# ===========================================
# EmailJS Configuration
# Get these from https://www.emailjs.com/
# ===========================================
VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

# ===========================================
# Application Configuration
# ===========================================
VITE_APP_URL=https://adv-vinayakamte.vercel.app
VITE_APP_NAME=Advocate Vinayak Amte

# ===========================================
# Analytics (Optional)
# Uncomment and add your analytics IDs
# ===========================================
# VITE_GA_TRACKING_ID=your_google_analytics_id
# VITE_GTM_ID=your_google_tag_manager_id

# ===========================================
# Notes:
# 1. Copy this file to .env and fill in real values
# 2. Never commit .env to version control
# 3. EmailJS is used for contact form submissions
# 4. Get your EmailJS credentials from: https://dashboard.emailjs.com/
# ===========================================